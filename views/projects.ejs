<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Projeler | <%= settings.site_name || 'Portfolio' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <canvas id="bg-canvas"></canvas>
  <nav class="navbar">
    <div class="nav-logo">
      <div class="logo-mark"><svg width="22" height="22" viewBox="0 0 28 28"><polygon points="14,2 26,24 2,24" fill="white"/></svg></div>
      <span class="logo-text"><%= settings.site_name || 'Dev.Portfolio' %></span>
    </div>
    <div class="nav-links">
      <a href="/">Ana Sayfa</a>
      <a href="/projects">Projeler</a>
      <a href="/#skills">Yetenekler</a>
      <a href="/#contact">İletişim</a>
    </div>
    <div class="nav-actions">
      <a href="/#contact" class="btn-nav-primary">İletişime Geç</a>
    </div>
  </nav>
  <section class="projects-section" style="padding-top:120px">
    <div class="section-header">
      <div class="section-tag">/ Tüm Projeler</div>
      <h2 class="section-title">Çalışmalarım</h2>
      <p class="section-desc">Geliştirdiğim tüm projeler ve mevcut durumları</p>
      <div class="filter-tabs">
        <button class="filter-btn active" data-filter="all">Tümü</button>
        <button class="filter-btn" data-filter="delivered">Teslim Edildi</button>
        <button class="filter-btn" data-filter="in_progress">Devam Ediyor</button>
        <button class="filter-btn" data-filter="web">Web</button>
        <button class="filter-btn" data-filter="mobile">Mobil</button>
        <button class="filter-btn" data-filter="ai">AI</button>
      </div>
    </div>
    <div class="projects-grid" id="projectsGrid">
      <% projects.forEach(function(project) { %>
      <div class="project-card" data-status="<%= project.status %>" data-category="<%= project.category %>">
        <div class="card-header">
          <div class="project-category"><%= project.category.toUpperCase() %></div>
          <div class="project-status status-<%= project.status %>">
            <span class="status-dot"></span>
            <%= project.status === 'delivered' ? 'Teslim Edildi' : project.status === 'in_progress' ? 'Devam Ediyor' : 'Planlanıyor' %>
          </div>
        </div>
        <div class="card-body">
          <h3 class="project-title"><%= project.title %></h3>
          <p class="project-desc"><%= project.description %></p>
          <div class="tech-stack">
            <% project.tech_stack.split(',').slice(0,4).forEach(function(tech) { %>
            <span class="tech-tag"><%= tech.trim() %></span>
            <% }) %>
          </div>
        </div>
        <div class="card-footer">
          <% if (project.start_date) { %>
          <span class="project-date"><%= new Date(project.start_date).toLocaleDateString('tr-TR', {month:'short', year:'numeric'}) %><% if (project.status === 'in_progress') { %> → devam ediyor<% } %></span>
          <% } %>
          <div class="card-links">
            <% if (project.github_url) { %><a href="<%= project.github_url %>" target="_blank" class="card-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg></a><% } %>
            <a href="/projects/<%= project.id %>" class="card-link card-link-detail">Detay →</a>
          </div>
        </div>
        <% if (project.status === 'in_progress') { %><div class="card-progress-bar"><div class="progress-inner"></div></div><% } %>
      </div>
      <% }) %>
    </div>
  </section>
  <script src="/js/main.js"></script>
</body>
</html>
