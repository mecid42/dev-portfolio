<%- include('_sidebar', { page: 'settings', adminUsername }) %>
  <div class="main">
    <div class="topbar"><div class="page-title">Site Ayarları</div></div>
    <div class="content">
      <% if (success) { %><div class="alert alert-success">✓ Kaydedildi.</div><% } %>

      <!-- ══════════════ LOGO ══════════════ -->
      <div class="form-card">
        <h3 class="card-section-title">🖼️ Logo</h3>
        <p style="color:#555;font-size:12px;margin-bottom:20px">Navbar ve footer'da görünür. Şeffaf arka planlı PNG önerilir. Max 2MB.</p>
        <div style="display:flex;align-items:center;gap:24px;flex-wrap:wrap">
          <div id="logoPreviewBox" style="width:80px;height:80px;border:1px solid rgba(255,255,255,0.08);border-radius:10px;display:flex;align-items:center;justify-content:center;background:#111;flex-shrink:0">
            <% if (settings.logo_url) { %>
              <img id="logoPreview" src="<%= settings.logo_url %>" style="max-width:60px;max-height:60px;object-fit:contain">
            <% } else { %>
              <svg width="36" height="36" viewBox="0 0 28 28"><polygon points="14,2 26,24 2,24" fill="none" stroke="white" stroke-width="2.2" stroke-linejoin="round"/><polygon points="14,2 26,24 2,24" fill="white" opacity="0.15"/></svg>
            <% } %>
          </div>
          <div>
            <div id="logoDropzone" onclick="document.getElementById('logoFileInput').click()"
                 ondragover="event.preventDefault();this.style.borderColor='#3b82f6'"
                 ondragleave="this.style.borderColor='rgba(255,255,255,0.12)'"
                 ondrop="handleLogoDrop(event)"
                 style="border:1px dashed rgba(255,255,255,0.12);border-radius:8px;padding:16px 28px;cursor:pointer;text-align:center;min-width:200px">
              <div style="font-size:20px;margin-bottom:4px">📁</div>
              <div style="color:#666;font-size:12px">Tıkla veya sürükle bırak</div>
              <div style="color:#333;font-size:10px;margin-top:3px;font-family:'JetBrains Mono',monospace">PNG · SVG · WebP</div>
            </div>
            <input type="file" id="logoFileInput" accept="image/*" style="display:none" onchange="uploadLogo(this.files[0])">
            <div style="display:flex;gap:8px;margin-top:8px;align-items:center">
              <div id="logoUploadStatus" style="font-size:11px;color:#555;font-family:'JetBrains Mono',monospace"></div>
              <% if (settings.logo_url) { %>
              <form method="POST" action="/admin/settings/logo/remove" style="margin:0">
                <button type="submit" class="action-btn delete" onclick="return confirm('Varsayılan üçgen logoya dön?')">Kaldır</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- ══════════════ GENEL ══════════════ -->
      <div class="form-card">
        <h3 class="card-section-title">⚙️ Genel Bilgiler</h3>
        <form method="POST" action="/admin/settings">
          <div class="form-row">
            <div class="form-group"><label>Site Adı (Logo Yanı)</label><input type="text" name="site_name" class="form-control" value="<%= settings.site_name||'' %>" placeholder="DEV.IO"></div>
            <div class="form-group"><label>E-posta</label><input type="email" name="email" class="form-control" value="<%= settings.email||'' %>" placeholder="hello@example.com"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>GitHub URL</label><input type="url" name="github_url" class="form-control" value="<%= settings.github_url||'' %>"></div>
            <div class="form-group"><label>LinkedIn URL</label><input type="url" name="linkedin_url" class="form-control" value="<%= settings.linkedin_url||'' %>"></div>
          </div>
          <div class="form-group"><label>CV Dosya URL</label><input type="url" name="cv_url" class="form-control" value="<%= settings.cv_url||'' %>" placeholder="https://...cv.pdf"></div>
          <div class="form-group"><label>Footer Yazısı</label><input type="text" name="footer_text" class="form-control" value="<%= settings.footer_text||'' %>" placeholder="Türkiye'den dünyaya kod yazıyorum 🇹🇷"></div>
          <div class="form-actions"><button type="submit" class="btn-sm primary">Kaydet →</button></div>
        </form>
      </div>

      <!-- ══════════════ HERO ══════════════ -->
      <div class="form-card">
        <h3 class="card-section-title">🚀 Hero Bölümü</h3>
        <form method="POST" action="/admin/settings">
          <div class="form-group"><label>Ana Başlık (Büyük harf)</label><input type="text" name="hero_title" class="form-control" value="<%= settings.hero_title||'' %>" placeholder="BUILDING THE FUTURE"></div>
          <div class="form-group"><label>Alt Başlık</label><input type="text" name="hero_subtitle" class="form-control" value="<%= settings.hero_subtitle||'' %>" placeholder="Full-Stack Developer & Computer Engineer"></div>
          <div class="form-actions"><button type="submit" class="btn-sm primary">Kaydet →</button></div>
        </form>
      </div>

      <!-- ══════════════ HAKKIMDA ══════════════ -->
      <div class="form-card">
        <h3 class="card-section-title">👤 Hakkımda Bölümü</h3>
        <form method="POST" action="/admin/settings">
          <div class="form-row">
            <div class="form-group"><label>Bölüm Başlığı ("Merhaba, Ben")</label><input type="text" name="about_title" class="form-control" value="<%= settings.about_title||'' %>" placeholder="Merhaba, Ben"></div>
            <div class="form-group"><label>Alt Başlık ("Yazılım Mühendisi")</label><input type="text" name="about_sub" class="form-control" value="<%= settings.about_sub||'' %>" placeholder="Bir Yazılım Mühendisiyim"></div>
          </div>
          <div class="form-group"><label>Açıklama Metni</label><textarea name="about_text" class="form-control" rows="3" placeholder="Kendinizi tanıtın..."><%= settings.about_text||'' %></textarea></div>
          <div class="form-actions"><button type="submit" class="btn-sm primary">Kaydet →</button></div>
        </form>
      </div>

      <!-- ══════════════ TERMINAL KARTI ══════════════ -->
      <div class="form-card">
        <h3 class="card-section-title">🖥️ Terminal Kartı (about.json)</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
          <form method="POST" action="/admin/settings">
            <div class="form-group"><label>"name"</label><input type="text" name="about_name" class="form-control" value="<%= settings.about_name||'' %>" placeholder="Full-Stack Developer"></div>
            <div class="form-group"><label>"education"</label><input type="text" name="about_education" class="form-control" value="<%= settings.about_education||'' %>" placeholder="Bilgisayar Mühendisliği"></div>
            <div class="form-group"><label>"experience"</label><input type="text" name="about_experience" class="form-control" value="<%= settings.about_experience||'' %>" placeholder="3+ years"></div>
            <div class="form-group"><label>"location"</label><input type="text" name="about_location" class="form-control" value="<%= settings.about_location||'' %>" placeholder="Türkiye 🇹🇷"></div>
            <div class="form-group"><label>"status"</label><input type="text" name="about_status" class="form-control" value="<%= settings.about_status||'' %>" placeholder="available"></div>
            <div class="form-group"><label>"coffee"</label><input type="text" name="about_coffee" class="form-control" value="<%= settings.about_coffee||'' %>" placeholder="∞"></div>
            <div class="form-group"><label>"passion" [0]</label><input type="text" name="about_passion_1" class="form-control" value="<%= settings.about_passion_1||'' %>" placeholder="Clean Code"></div>
            <div class="form-group"><label>"passion" [1]</label><input type="text" name="about_passion_2" class="form-control" value="<%= settings.about_passion_2||'' %>" placeholder="Performance"></div>
            <div class="form-group"><label>"passion" [2]</label><input type="text" name="about_passion_3" class="form-control" value="<%= settings.about_passion_3||'' %>" placeholder="Innovation"></div>
            <div class="form-actions"><button type="submit" class="btn-sm primary">Kaydet →</button></div>
          </form>

          <!-- Canlı önizleme -->
          <div style="background:#080808;border:1px solid rgba(255,255,255,0.07);border-radius:10px;overflow:hidden;align-self:start">
            <div style="background:#0f0f0f;padding:10px 14px;display:flex;align-items:center;gap:6px;border-bottom:1px solid rgba(255,255,255,0.07)">
              <span style="width:9px;height:9px;border-radius:50%;background:#ff5f56;display:inline-block"></span>
              <span style="width:9px;height:9px;border-radius:50%;background:#ffbd2e;display:inline-block"></span>
              <span style="width:9px;height:9px;border-radius:50%;background:#27c93f;display:inline-block"></span>
              <span style="margin-left:6px;color:#444;font-size:11px">about.json</span>
            </div>
            <pre style="padding:18px;font-family:'JetBrains Mono',monospace;font-size:11px;line-height:1.8;color:#ececec"><code><span style="color:#444">{</span>
  <span style="color:#7cb9e8">"name"</span>: <span style="color:#98c379">"<%= settings.about_name||'Full-Stack Developer' %>"</span>,
  <span style="color:#7cb9e8">"education"</span>: <span style="color:#98c379">"<%= settings.about_education||'Bilgisayar Mühendisliği' %>"</span>,
  <span style="color:#7cb9e8">"experience"</span>: <span style="color:#98c379">"<%= settings.about_experience||'3+ years' %>"</span>,
  <span style="color:#7cb9e8">"location"</span>: <span style="color:#98c379">"<%= settings.about_location||'Türkiye 🇹🇷' %>"</span>,
  <span style="color:#7cb9e8">"status"</span>: <span style="color:#22c55e">"<%= settings.about_status||'available' %>"</span>,
  <span style="color:#7cb9e8">"passion"</span>: [
    <span style="color:#98c379">"<%= settings.about_passion_1||'Clean Code' %>"</span>,
    <span style="color:#98c379">"<%= settings.about_passion_2||'Performance' %>"</span>,
    <span style="color:#98c379">"<%= settings.about_passion_3||'Innovation' %>"</span>
  ],
  <span style="color:#7cb9e8">"coffee"</span>: <span style="color:#d19a66"><%= settings.about_coffee||'∞' %></span>
<span style="color:#444">}</span></code></pre>
          </div>
        </div>
      </div>

    </div>
  </div>

  <style>
  .card-section-title { font-family:'Syne',sans-serif; font-size:14px; font-weight:700; color:#ececec; margin-bottom:16px; padding-bottom:12px; border-bottom:1px solid rgba(255,255,255,0.06); }
  </style>

  <script>
  async function uploadLogo(file) {
    if (!file) return;
    if (file.size > 2*1024*1024) { alert('Dosya 2MB\'dan büyük!'); return; }
    const status = document.getElementById('logoUploadStatus');
    status.textContent = 'Yükleniyor...'; status.style.color='#3b82f6';
    const buf = await file.arrayBuffer();
    const res = await fetch('/admin/settings/logo', { method:'POST', headers:{'Content-Type':file.type}, body:buf });
    const data = await res.json();
    if (data.success) {
      document.getElementById('logoPreviewBox').innerHTML = `<img src="${data.url}" style="max-width:60px;max-height:60px;object-fit:contain">`;
      status.textContent = '✓ Logo güncellendi — sayfayı yenile'; status.style.color='#22c55e';
    } else { status.textContent = '❌ Hata'; status.style.color='#ef4444'; }
  }
  function handleLogoDrop(e) {
    e.preventDefault();
    document.getElementById('logoDropzone').style.borderColor='rgba(255,255,255,0.12)';
    const file = e.dataTransfer.files[0];
    if (file?.type.startsWith('image/')) uploadLogo(file);
  }
  </script>
</body></html>
