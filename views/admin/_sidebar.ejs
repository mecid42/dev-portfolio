<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#070707;--bg2:#0d0d0d;--bg3:#131313;--bgc:#0f0f0f;--b:rgba(255,255,255,0.07);--bh:rgba(255,255,255,0.14);--txt:#e8e8e8;--muted:#555;--dim:#888;--blue:#3b82f6;--green:#22c55e;--orange:#f97316;--red:#ef4444;--sw:250px}
    body{background:var(--bg);color:var(--txt);font-family:'JetBrains Mono',monospace;font-size:13px;display:flex;min-height:100vh}
    .sidebar{width:var(--sw);min-height:100vh;background:var(--bg2);border-right:1px solid var(--b);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;overflow-y:auto}
    .sidebar-logo{display:flex;align-items:center;gap:10px;padding:20px;border-bottom:1px solid var(--b);font-family:'Syne',sans-serif;font-weight:800;font-size:15px;letter-spacing:1px}
    .sidebar-nav{flex:1;padding:12px 0}
    .nav-section{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);padding:14px 18px 6px}
    .nav-item{display:flex;align-items:center;justify-content:space-between;padding:9px 18px;color:var(--muted);text-decoration:none;transition:all .15s;border-left:2px solid transparent;font-size:12px}
    .nav-item:hover{color:var(--txt);background:rgba(255,255,255,0.03)}
    .nav-item.active{color:var(--txt);border-left-color:var(--blue);background:rgba(59,130,246,0.06)}
    .nav-item-left{display:flex;align-items:center;gap:9px}
    .nav-item svg{width:14px;height:14px;flex-shrink:0}
    .nav-badge{padding:2px 7px;border-radius:100px;font-size:10px;background:#ef4444;color:#fff;font-weight:700}
    .sidebar-footer{padding:14px 18px;border-top:1px solid var(--b)}
    .sidebar-user{display:flex;align-items:center;gap:10px;margin-bottom:10px}
    .user-avatar{width:28px;height:28px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
    .user-name{font-size:12px;color:var(--txt)}
    .user-role{font-size:10px;color:var(--muted)}
    .btn-logout{display:flex;align-items:center;justify-content:center;gap:7px;padding:7px;border:1px solid var(--b);border-radius:6px;color:var(--muted);text-decoration:none;font-size:11px;transition:all .2s;width:100%}
    .btn-logout:hover{border-color:rgba(239,68,68,.4);color:var(--red);background:rgba(239,68,68,.05)}
    .main{margin-left:var(--sw);flex:1;display:flex;flex-direction:column;min-width:0}
    .topbar{display:flex;align-items:center;justify-content:space-between;padding:15px 28px;border-bottom:1px solid var(--b);background:var(--bg2);flex-shrink:0}
    .page-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:700}
    .topbar-actions{display:flex;gap:9px}
    .btn-sm{padding:7px 14px;border:1px solid var(--b);border-radius:6px;color:var(--muted);text-decoration:none;font-size:11px;font-family:'JetBrains Mono',monospace;background:none;cursor:pointer;transition:all .2s}
    .btn-sm:hover{border-color:var(--bh);color:var(--txt)}
    .btn-sm.primary{background:#fff;border-color:#fff;color:#000}
    .btn-sm.primary:hover{background:#e5e5e5}
    .content{padding:28px;flex:1}
    .stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(165px,1fr));gap:14px;margin-bottom:28px}
    .stat-card{background:var(--bgc);border:1px solid var(--b);border-radius:10px;padding:18px}
    .stat-card-label{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:9px}
    .stat-card-num{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;letter-spacing:-1px;color:#fff}
    .stat-card-sub{font-size:10px;color:var(--muted);margin-top:4px}
    .table-wrap{background:var(--bgc);border:1px solid var(--b);border-radius:10px;overflow:hidden;margin-bottom:20px}
    .table-header{padding:14px 18px;border-bottom:1px solid var(--b);display:flex;justify-content:space-between;align-items:center}
    .table-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700}
    table{width:100%;border-collapse:collapse}
    th{padding:9px 18px;text-align:left;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--b);white-space:nowrap}
    td{padding:11px 18px;border-bottom:1px solid var(--b);color:var(--dim);font-size:12px}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:rgba(255,255,255,0.015)}
    .charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px}
    .chart-card{background:var(--bgc);border:1px solid var(--b);border-radius:10px;padding:18px}
    .chart-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;margin-bottom:16px}
    .badge{padding:2px 8px;border-radius:4px;font-size:10px}
    .badge-green{background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.3);color:var(--green)}
    .badge-blue{background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.3);color:var(--blue)}
    .badge-orange{background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.3);color:var(--orange)}
    .badge-red{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:var(--red)}
    .form-card{background:var(--bgc);border:1px solid var(--b);border-radius:10px;padding:24px;margin-bottom:20px}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
    .form-group{margin-bottom:14px}
    .form-group label{display:block;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:7px}
    .form-control{width:100%;padding:9px 13px;background:var(--bg3);border:1px solid var(--b);border-radius:6px;color:var(--txt);font-family:'JetBrains Mono',monospace;font-size:12px;outline:none;transition:border-color .2s;resize:vertical}
    .form-control:focus{border-color:rgba(59,130,246,.5)}
    select.form-control{cursor:pointer}
    .form-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:20px}
    .action-btn{display:inline-flex;align-items:center;gap:5px;padding:5px 11px;border-radius:6px;font-size:11px;cursor:pointer;text-decoration:none;transition:all .2s;border:1px solid;font-family:'JetBrains Mono',monospace;background:none}
    .action-btn.edit{border-color:var(--b);color:var(--muted)}
    .action-btn.edit:hover{border-color:var(--bh);color:var(--txt)}
    .action-btn.delete{border-color:rgba(239,68,68,.3);color:var(--red)}
    .action-btn.delete:hover{background:rgba(239,68,68,.1)}
    .alert{padding:11px 15px;border-radius:8px;margin-bottom:18px;font-size:12px}
    .alert-success{background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.3);color:var(--green)}
    @media(max-width:900px){.sidebar{display:none}.main{margin-left:0}.charts-grid{grid-template-columns:1fr}.form-row{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <aside class="sidebar">
    <div class="sidebar-logo">
      <svg width="20" height="20" viewBox="0 0 28 28">
        <polygon points="14,2 26,24 2,24" fill="none" stroke="white" stroke-width="2.2" stroke-linejoin="round"/>
        <polygon points="14,2 26,24 2,24" fill="white" opacity="0.15"/>
      </svg>
      ADMIN PANEL
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">GENEL</div>
      <a href="/admin" class="nav-item <%= page==='dashboard'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Dashboard</div>
      </a>
      <a href="/admin/visitors" class="nav-item <%= page==='visitors'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>Ziyaretçi</div>
      </a>

      <div class="nav-section">SAYFA İÇERİĞİ</div>
      <a href="/admin/hero" class="nav-item <%= page==='hero'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 28 28"><polygon points="14,2 26,24 2,24" fill="currentColor"/></svg>Hero Bölümü</div>
      </a>
      <a href="/admin/about" class="nav-item <%= page==='about'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>Hakkımda</div>
      </a>
      <a href="/admin/experience" class="nav-item <%= page==='experience'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>Deneyim</div>
      </a>
      <a href="/admin/skills" class="nav-item <%= page==='skills'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>Yetenekler</div>
      </a>
      <a href="/admin/contact-settings" class="nav-item <%= page==='contact-settings'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>İletişim</div>
      </a>
      <a href="/admin/settings" class="nav-item <%= page==='settings'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>Site Ayarları</div>
      </a>

      <div class="nav-section">PROJELER & ETKİLEŞİM</div>
      <a href="/admin/projects" class="nav-item <%= page==='projects'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>Projeler</div>
      </a>
      <a href="/admin/subscribers" class="nav-item <%= page==='subscribers'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>Aboneler</div>
      </a>
      <a href="/admin/likes" class="nav-item <%= page==='likes'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>Beğeniler</div>
      </a>

      <div class="nav-section">SİSTEM</div>
      <a href="/admin/messages" class="nav-item <%= page==='messages'?'active':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>Mesajlar</div>
        <% const unread = typeof stats !== 'undefined' ? stats.unread_messages : 0; %>
        <% if (unread > 0) { %><span class="nav-badge"><%= unread %></span><% } %>
      </a>
      <a href="/admin/danger" class="nav-item <%= page==='danger'?'active':'' %>" style="color:<%= page==='danger'?'#ef4444':'' %>">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>Tehlikeli Alan</div>
      </a>
      <a href="/" target="_blank" class="nav-item">
        <div class="nav-item-left"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>Siteyi Gör ↗</div>
      </a>
    </nav>
    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="user-avatar"><%= adminUsername ? adminUsername[0].toUpperCase() : 'A' %></div>
        <div>
          <div class="user-name"><%= adminUsername || 'Admin' %></div>
          <div class="user-role">Administrator</div>
        </div>
      </div>
      <a href="/admin/logout" class="btn-logout">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Çıkış Yap
      </a>
    </div>
  </aside>
